# MySQL (Laragon)
# Créer la base : smartcampus (HeidiSQL ou phpMyAdmin)
# Adapter user / password (souvent root sans mot de passe en local)

DATABASE_URL=mysql+pymysql://root:@localhost:3306/smartcampus?charset=utf8mb4

# Sécurité
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Agent IA
AGENT_SERVICE_KEY=agent-demo-key
LLM_ENDPOINT=http://localhost:11434/v1
DEMO_MODE=true

# WhatsApp (optionnel hackathon)
WHATSAPP_TOKEN=

# App
APP_NAME=SmartCampus AgentAI
DEBUG=true
CURRENCY_DEFAULT=CDF
