# Copier vers .env.production sur le serveur (NE PAS COMMITER)
# cp .env.production.example .env.production

# MySQL (conteneur docker-compose.prod ou serveur Yamify)
DATABASE_URL=mysql+pymysql://smartcampus:CHANGER_MOT_DE_PASSE@db:3306/smartcampus?charset=utf8mb4

# Sécurité — générer une clé forte : openssl rand -hex 32
JWT_SECRET=CHANGER_EN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Agent IA — LLM local / souverain uniquement (jamais OpenAI US en prod démo)
AGENT_SERVICE_KEY=CHANGER_CLE_AGENT
LLM_ENDPOINT=http://host.docker.internal:11434/v1
DEMO_MODE=true

WHATSAPP_TOKEN=

APP_NAME=SmartCampus AgentAI
DEBUG=false
CURRENCY_DEFAULT=CDF

# CORS — domaines front autorisés (séparés par des virgules)
CORS_ORIGINS=https://smartcampus.votredomaine.cd,https://www.votredomaine.cd

# Premier déploiement : charger les données démo hackathon
SEED_DEMO=true
