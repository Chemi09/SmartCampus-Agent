# Base de données — SQLite (dev) ou PostgreSQL (démo / prod)
DATABASE_URL=sqlite:///./smartcampus.db
# DATABASE_URL=postgresql://smartcampus:smartcampus@localhost:5432/smartcampus

# Sécurité
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Agent IA
AGENT_SERVICE_KEY=agent-demo-key
LLM_ENDPOINT=http://localhost:11434/v1
DEMO_MODE=true

# WhatsApp (optionnel hackathon)
WHATSAPP_TOKEN=

# App
APP_NAME=SmartCampus AgentAI
DEBUG=true
CURRENCY_DEFAULT=CDF
